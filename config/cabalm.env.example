# Copy this file to ~/CabalmMacKit/config/cabalm.env and edit paths if needed.

# Keep the host VPN running. The scripts never stop V2Box/Karing by default.
STOP_HOST_VPN_FOR_GAME=0
ALLOW_HOST_VPN_STOP_FOR_GAME=0

# Install/work area. External disk example:
# export CABALM_HOME=/Volumes/DDISK/macOS/CabalmMacKit
CABALM_HOME="${CABALM_HOME:-$HOME/CabalmMacKit}"

# Android SDK and AVD locations.
ANDROID_HOME="$HOME/Library/Android/sdk"
ANDROID_SDK_ROOT="$HOME/Library/Android/sdk"
CABALM_AVD_HOME="$HOME/.android/avd"

# Default instance.
SERIAL=emulator-5554
AVD_NAME=macos_game_a9_01
EMULATOR_PORT=5554

# GPU notes:
# - screen launch keeps qemu outside Codex/Terminal cleanup and avoids extra Terminal windows.
# - set EMULATOR_SDK_ROOT/EMULATOR_BIN to a pinned emulator copy when SDK updates are unstable.
# EMULATOR_SDK_ROOT=/Volumes/DDISK/macOS/Android/emulator_versions/37.1.2
# EMULATOR_BIN=/Volumes/DDISK/macOS/Android/emulator_versions/37.1.2/emulator/emulator
GPU_MODE=swangle
MEMORY_MB=6144
CORES=4
FPS=30
EMULATOR_LAUNCH_METHOD=screen
LOAD_WAIT_SECONDS=600
POST_DATA_WAIT_SECONDS=45
PIXEL_DETECTION_ENABLED=0
SCREENSHOT_ENABLED=0

# Correct network defaults found during troubleshooting.
GAME_HOSTS_OVERRIDE=0
GAME_HOSTS_IP=
GAME_HOSTS_FALLBACK_IP=
GAME_DIRECT_HTTP_PROXY=1
GAME_DIRECT_TCP_PROXY=1
GAME_DIRECT_PROXY_IFACE=en1

# Game version database guard.
GAME_VERSION_GUARD=1
GAME_VERSION_TYPE0=55
GAME_VERSION_TYPE1=8
